# Supabase (self-hosted on Coolify — use your public Kong/API URL)
NEXT_PUBLIC_SUPABASE_URL=https://supabase.your-domain.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt

# Server-only (never commit real values)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# Local dev site URL (used for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: match Coolify Supabase JWT secret when regenerating keys
# GOTRUE_JWT_SECRET=your-service-password-jwt-from-coolify
